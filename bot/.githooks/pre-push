#!/usr/bin/env bash
# Valida nome da branch seguindo git-flow antes do push.
# Ative com: git config core.hooksPath .githooks

protected_long='^(main|develop|master)$'
gitflow='^(feature|release|hotfix|bugfix|support|chore|docs)\/[a-z0-9._-]+$'

current_branch="$(git symbolic-ref --short HEAD 2>/dev/null)"

if [ -z "$current_branch" ]; then
  exit 0
fi

if [[ "$current_branch" =~ $protected_long ]]; then
  exit 0
fi

if [[ ! "$current_branch" =~ $gitflow ]]; then
  echo ""
  echo "[pre-push] Branch '$current_branch' nao segue o padrao git-flow."
  echo "Use: feature/<slug>, release/<slug>, hotfix/<slug>, bugfix/<slug>, support/<slug>, chore/<slug> ou docs/<slug>"
  echo "Slug em kebab-case: a-z, 0-9, ponto, underline, hifen."
  echo "Ex.: feature/jooble-partial-criteria, hotfix/fix-login-redirect"
  echo ""
  exit 1
fi

exit 0
