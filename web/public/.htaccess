# MIME types explicitos para os bundles do Vite (evita servidor cair em
# default text/html quando, por algum motivo, o tipo nao for inferido).
<IfModule mod_mime.c>
  AddType text/css                .css
  AddType application/javascript  .js
  AddType application/javascript  .mjs
  AddType application/json        .json
  AddType image/svg+xml           .svg
  AddType font/woff2              .woff2
  AddType font/woff               .woff
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # If an existing asset or directory is requested go to it as it is
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -f [OR]
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -d
  RewriteRule ^ - [L]

  # /assets/* nunca cai no fallback do SPA: se o arquivo nao existir,
  # devolve 404 real para o browser nao tentar aplicar HTML como CSS/JS
  # (causa do "Refused to apply style ... MIME type 'text/html'").
  RewriteCond %{REQUEST_URI} ^/assets/
  RewriteRule ^ - [R=404,L]

  # If the requested resource doesn't exist, use index.html
  RewriteRule ^ /index.html [L]
</IfModule>

# Security Headers
<IfModule mod_headers.c>
  # Anti-clickjacking - frame-ancestors em CSP só funciona via header HTTP,
  # então X-Frame-Options DENY cobre a defesa em todos os navegadores.
  Header always set X-Frame-Options "DENY"

  # Bloqueia MIME-sniffing.
  Header always set X-Content-Type-Options "nosniff"

  # Vazamento de URL referer minimizado.
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # X-XSS-Protection é deprecated em browsers modernos (Chrome removeu);
  # a proteção real vem da CSP definida no <meta> de index.html.
  Header always set X-XSS-Protection "0"

  # HSTS - força HTTPS por 1 ano. preload exige inscrição em hstspreload.org.
  # Se ainda houver dúvida sobre HTTPS em todos os subdomínios, remover
  # includeSubDomains até validar.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # Desabilita features de hardware/sensor que a app não usa.
  # payment=(self) permite Payment Request API só na origem (Stripe Checkout
  # roda em iframe, não precisa).
  Header always set Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(self), usb=(), interest-cohort=()"

  # Isolamento cross-origin - limita ataques tipo Spectre.
  # COOP same-origin: janelas abertas por outras origens não compartilham
  # browsing context. CORP same-site: este site só pode ser carregado como
  # recurso por origens do mesmo registrable domain.
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-site"

  # Assets com hash sao imutaveis: cache agressivo (1 ano).
  <FilesMatch "\.(?:css|js|mjs|woff2?|ttf|eot|otf|png|jpg|jpeg|gif|webp|avif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # index.html nunca em cache: sempre apontar para o build mais recente.
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

# Enable Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 year"
</IfModule>
