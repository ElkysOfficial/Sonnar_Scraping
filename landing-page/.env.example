# Supabase Configuration (Frontend)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id

# Public contact (somente dígitos, com DDI). Ex.: 5511999999999
# Se vazio, o botão "Falar no WhatsApp" da landing fica oculto.
VITE_WHATSAPP_PHONE=

# E-mail do owner para bootstrap (acessa /admin mesmo sem linha em user_roles).
# Útil pra recuperação pós-reset de banco. Se vazio, owner precisa estar em user_roles.
VITE_OWNER_EMAIL=

# Secrets configurados em Supabase Edge Functions environment:
# - STRIPE_SECRET_KEY        (Stripe API secret key)
# - STRIPE_WEBHOOK_SECRET    (Stripe webhook signing secret)
# - STRIPE_PRICE_PRO         (price_xxx do plano Pro no Stripe)
# - STRIPE_PRICE_PLUS        (price_xxx do plano Plus no Stripe)
# - RESEND_API_KEY           (Resend email service API key)
# - OWNER_EMAIL              (email do owner - usado por create-owner-account)
# - OWNER_PASSWORD           (senha inicial do owner - rotacionar após primeiro login)
# - OWNER_FULL_NAME          (opcional, default "Owner")
# - SUPABASE_SERVICE_ROLE_KEY (auto-injected by Supabase)
# - SUPABASE_URL              (auto-injected by Supabase)
