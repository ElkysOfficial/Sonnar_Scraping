# =====================================================
# Variaveis de ambiente do bot do WhatsApp (Sonar Bot)
# Copie para .env e preencha. O .env real NAO eh versionado.
# =====================================================

# --- Supabase do BOT (obrigatorio - bot nao sobe sem isso) ---
SUPABASE_URL=https://<projeto-do-bot>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-do-projeto-do-bot>

# --- Pareamento com o portal web ---
# URL base das edge functions do Supabase do PORTAL (projeto diferente do bot).
WEB_FUNCTIONS_URL=https://cqiaiwpjrxqxvhvmcgfs.supabase.co/functions/v1
# Segredo compartilhado com a edge function link-whatsapp.
# DEVE ser igual ao secret configurado no Supabase do portal.
WHATSAPP_LINK_SECRET=<mesmo-valor-do-supabase-secrets-set>

# --- APIs internas ---
CORE_API_URL=http://localhost:3100
CARD_API_URL=http://localhost:3001
ENABLE_API_RECEIVER=true
WHATSAPP_API_PORT=3002
# Token de autenticacao do API Receiver (/send e /send-batch).
# Gere um valor aleatorio forte: openssl rand -hex 32
# O MESMO valor deve ir nos secrets do Supabase do site (WHATSAPP_API_TOKEN).
# Sem este valor, a API recusa todas as requisicoes externas.
WHATSAPP_API_TOKEN=

# --- Opcionais (tem default no config.js) ---
LOG_LEVEL=success
USE_CARD_SENDER=true
