# Supabase (escrita server-side via service_role)
# NUNCA versione o .env real. Esta chave eh full-access - bypassa RLS.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# message-formatting-core: o scraper envia as vagas coletadas para o core,
# que eh o unico processo que grava o jobs.json (single-writer).
# Default: http://localhost:3100
# CORE_API_URL=http://localhost:3100

# Intervalo (segundos) do envio periodico de vagas ao core. Default: 5
# CORE_PUSH_INTERVAL_S=5

# Vagas por request no envio ao core. Minimo 1; invalido cai em 500. Default: 500
# CORE_PUSH_CHUNK_SIZE=500

# Careerjet - API oficial de busca de vagas (engine careerjet).
# Autenticacao Basic Auth (usuario=chave, senha=vazia). A chave e vinculada
# a um IP autorizado: chamadas de outro IP falham.
CAREERJET_API_KEY=your-careerjet-api-key-here
# Tunaveis opcionais (com defaults sensatos):
# CAREERJET_LOCALE=pt_BR              # indice de busca (pais/idioma)
# CAREERJET_USER_IP=82.25.68.106      # IP autorizado para a chave
# CAREERJET_REFERER=https://elkys.com.br/find-jobs/
# CAREERJET_MAX_PAGES=3               # paginas por stack/UF (20 vagas/pagina)
# CAREERJET_FRAGMENT_SIZE=2000        # tamanho do excerto da descricao
