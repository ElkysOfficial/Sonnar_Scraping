# Porta do servidor HTTP
MESSAGE_FORMATTING_CORE_PORT=3100

# Caminho absoluto do jobs.json. O core eh o UNICO processo que grava este
# arquivo (single-writer); o scraper envia as vagas via POST /jobs/batch.
# Default: <repo>/apps/scraper/src/data/jobs.json (resolvido a partir de src/server.js)
# JOBS_JSON_PATH=/caminho/absoluto/para/jobs.json

# Janela de retencao: vagas com publication_date mais antigo que isto sao
# removidas do jobs.json no boot e a cada 6h. Valor minimo 1; invalido cai em 90.
# JOBS_MAX_AGE_DAYS=90
